generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Users {
  userId    String      @id @default(uuid())
  email     String      @unique
  password  String?
  fullName  String
  role      UserStatus  @default(FARMER)
  listings  Listings[]  @relation("UserListings")
  cropScans CropScans[] @relation("UserCropScans")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

enum UserStatus {
  FARMER
  BUYER
}

model Listings {
  listingId   String     @id @default(uuid())
  title       String
  description String
  price       Decimal
  quantity    Int
  category    Categories @default(CROPS)
  location    String
  farmer      Users      @relation("UserListings", fields: [farmerId], references: [userId])
  farmerId    String
  scan        CropScans?  @relation(fields: [scanId], references: [cropScanId])
  scanId      String?     @unique
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

enum Categories {
  CROPS
  LIVESTOCK
  PRODUCE
  OTHER
}

model CropScans {
  cropScanId      String       @id @default(uuid())
  farmer          Users        @relation("UserCropScans", fields: [farmerId], references: [userId])
  farmerId        String
  healthStatus    HealthStatus
  spoilageRisk    SpoilageRisk
  confidenceScore Int
  recommendation  String
  listing         Listings?
  createdAt       DateTime     @default(now())
}

enum HealthStatus {
  GOOD
  DISEASED
  BAD
}

enum SpoilageRisk {
  LOW
  MEDIUM
  HIGH
}

model Payment {
  id          String   @id @default(uuid())
  listingId   String
  amount      Int      
  email       String
  status      String   // pending | success | failed
  reference   String   @unique
  createdAt   DateTime @default(now())
}